# ============================================================
# 竞品分析多Agent协作系统 — 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# ----------------------------------------------------------
# LLM — DeepSeek Chat API
# ----------------------------------------------------------
DEEPSEEK_API_KEY=competitive-analysis-system-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# ----------------------------------------------------------
# Database — PostgreSQL + pgvector
# ----------------------------------------------------------
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=competitive_analysis
PG_USER=postgres
PG_PASSWORD=competitive_analysis_pwd

# ----------------------------------------------------------
# Embedding — BGE-M3 (1024维)
# ----------------------------------------------------------
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu

# ----------------------------------------------------------
# Reranker — BGE-reranker-v2-m3
# ----------------------------------------------------------
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ----------------------------------------------------------
# Limits — 并发 & 频控
# ----------------------------------------------------------
MAX_CONCURRENT_COLLECTORS=3
MAX_ROUNDS_SUPERVISOR=10
TOKEN_BUCKET_CAPACITY=100
LLM_RPM_LIMIT=60